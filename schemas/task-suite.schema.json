{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thromel/helmbench/schemas/task-suite.schema.json",
  "title": "HelmBench Task Suite",
  "description": "Source-free benchmark task suite contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "tasks"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "^[A-Za-z]:"
          },
          {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        ]
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "expectedFiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/safeRelativePath"
          }
        },
        "expectedTests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/safeRelativePath"
          }
        },
        "successCommand": {
          "type": ["string", "null"]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeoutSeconds": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    }
  }
}
