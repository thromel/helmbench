{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thromel/helmbench/schemas/evidence-bundle.schema.json",
  "title": "HelmBench Evidence Bundle",
  "description": "Source-free manifest for a verifiable HelmBench evidence bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "suiteName",
    "baselineAgent",
    "baselineVariant",
    "evidenceUse",
    "artifacts",
    "privacy"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "suiteName": {
      "type": "string",
      "minLength": 1
    },
    "baselineAgent": {
      "type": "string",
      "minLength": 1
    },
    "baselineVariant": {
      "$ref": "#/$defs/agentVariant"
    },
    "evidenceUse": {
      "$ref": "#/$defs/evidenceUse"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    }
  },
  "$defs": {
    "agentVariant": {
      "enum": ["native", "native_search", "ctxhelm_plan", "ctxhelm_mcp", "ctxhelm_pack", "other"]
    },
    "evidenceUse": {
      "enum": ["outcome_ready", "navigation_only", "unhealthy"]
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "^[A-Za-z]:"
          },
          {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        ]
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "sourceName",
        "byteCount",
        "contentHash",
        "sourceFreeChecked"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "sourceName": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "[/\\\\]"
          }
        },
        "byteCount": {
          "type": "integer",
          "minimum": 0
        },
        "contentHash": {
          "type": "string",
          "pattern": "^fnv64:[0-9a-f]{16}$"
        },
        "sourceFreeChecked": {
          "const": true
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceFree",
        "rawSourceLogged",
        "rawPromptLogged",
        "rawTranscriptLogged",
        "rawTerminalLogged"
      ],
      "properties": {
        "sourceFree": {
          "const": true
        },
        "rawSourceLogged": {
          "const": false
        },
        "rawPromptLogged": {
          "const": false
        },
        "rawTranscriptLogged": {
          "const": false
        },
        "rawTerminalLogged": {
          "const": false
        }
      }
    }
  }
}
